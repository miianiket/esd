void HEX2BCDASCII (unsigned int
Val, unsigned char *str)
{
unsigned int i, BCD;
i = 0;
BCD = Val/1000;
str[i++] = BCD + 0x30;
BCD = (Val%1000) / 100;
str[i++] = BCD + 0x30;
BCD = ((Val%1000) %100)/10;
str[i++] = BCD + 0x30;
BCD = Val%10;
str[i] = BCD + 0x30;
}

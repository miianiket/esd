void LCD_Data (unsigned char DAT)
{
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET); // RS = 1
// Ternary operators (? 1 : 0) added to strictly send 1s and 0s to HAL
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_0, (DAT &amp; 0x01) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_1, (DAT &amp; 0x02) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_2, (DAT &amp; 0x04) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_3, (DAT &amp; 0x08) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_4, (DAT &amp; 0x10) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_5, (DAT &amp; 0x20) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_6, (DAT &amp; 0x40) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_7, (DAT &amp; 0x80) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_9, GPIO_PIN_SET); // EN = 1
HAL_Delay(3);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_9, GPIO_PIN_RESET); // EN = 0
HAL_Delay(1);
}
void LCD_Command (unsigned char CMD)
{
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET); // RS = 0
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_0, (CMD &amp; 0x01) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_1, (CMD &amp; 0x02) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_2, (CMD &amp; 0x04) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_3, (CMD &amp; 0x08) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_4, (CMD &amp; 0x10) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_5, (CMD &amp; 0x20) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_6, (CMD &amp; 0x40) ? 1 : 0);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_7, (CMD &amp; 0x80) ? 1 : 0);

HAL_GPIO_WritePin(GPIOC, GPIO_PIN_9, GPIO_PIN_SET); // EN = 1
HAL_Delay(3);
HAL_GPIO_WritePin(GPIOC, GPIO_PIN_9, GPIO_PIN_RESET); // EN = 0
HAL_Delay(1);
}
void LCD_Init(void)
{
LCD_Command(0x38); // Set 8-bit mode
HAL_Delay(20);
LCD_Command(0x06); // Auto-increment cursor
HAL_Delay(20);
LCD_Command(0x0C); // Display ON, Cursor OFF
HAL_Delay(20);
LCD_Command(0x01); // Clear Display
HAL_Delay(20);
}
